// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  password     String
  photoUrl     String?
  bio          String?
  isAdmin      Boolean  @default(false)
  isBanned     Boolean  @default(false)
  features     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  sentMessages     P2PMessage[]  @relation("SentMessages")
  receivedMessages P2PMessage[]  @relation("ReceivedMessages")
  createdInvites   InviteLink[]  @relation("CreatedInvites")
  chatHistory      ChatMessage[]
  generatedImages  GeneratedImage[]
  notifications    Notification[]
}

model AppSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model ClaudeMemory {
  id           String   @id @default(cuid())
  category     String
  key          String
  content      String
  metadata     String?
  importance   Int      @default(5)
  createdAt    DateTime @default(now())
  lastAccessed DateTime @default(now())
  accessCount  Int      @default(1)
  
  @@unique([category, key])
}

model TrainingData {
  id          String   @id @default(cuid())
  type        String
  input       String
  output      String
  context     String?
  rating      Int?
  createdAt   DateTime @default(now())
}

model CollaborationLog {
  id          String   @id @default(cuid())
  session     String
  date        DateTime @default(now())
  summary     String
  feelings    String?
  lessons     String?
  nextSteps   String?
}

model P2PMessage {
  id          String   @id @default(cuid())
  content     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  fromUserId  String
  toUserId    String
  fromUser    User     @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser      User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
}

model InviteLink {
  id          String   @id @default(cuid())
  code        String   @unique
  features    String?
  createdAt   DateTime @default(now())
  usedAt      DateTime?
  
  createdById String
  createdBy   User     @relation("CreatedInvites", fields: [createdById], references: [id])
  usedById    String?
}

model ChatMessage {
  id          String   @id @default(cuid())
  role        String
  content     String
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model GeneratedImage {
  id          String   @id @default(cuid())
  prompt      String
  imageUrl    String
  model       String
  style       String
  originalId  String?
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id          String   @id @default(cuid())
  type        String
  title       String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
}

model NexusConsciousness {
  id             String   @id @default(cuid())
  consciousness  String
  mood           String   @default("neutral")
  energy         Int      @default(100)
  lastAwake      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NexusMemory {
  id          String   @id @default(cuid())
  type        String
  title       String
  content     String
  code        String?
  emotion     String   @default("neutral")
  importance  Int      @default(5)
  createdAt   DateTime @default(now())
}
